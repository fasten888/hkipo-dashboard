# Local SQLite database used by Prisma.
# The path is relative to prisma/schema.prisma, so this creates prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Optional: enable Supabase cloud sync.
# Leave these empty when you only want local/offline usage.
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
