generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserData {
  userId    String   @id @map("user_id")
  data      String   @default("{}")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("user_data")
}
