generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserData {
  userId    String   @id @map("user_id")
  data      String   @default("{}")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("user_data")
}

model SyncLog {
  id        String    @id @default(cuid())
  provider  String
  status    String
  startTime DateTime  @map("start_time")
  endTime   DateTime? @map("end_time")
  added     Int       @default(0)
  updated   Int       @default(0)
  failed    Int       @default(0)
  message   String?

  @@index([provider])
  @@index([status])
  @@index([startTime])
  @@map("sync_log")
}

model Ipo {
  id                 String        @id @default(cuid())
  code               String        @unique
  name               String
  status             String        @default("draft")
  board              String?
  industry           String?
  offerPriceMin      Float?        @map("offer_price_min")
  offerPriceMax      Float?        @map("offer_price_max")
  lotSize            Int?          @map("lot_size")
  lotAmount          Float?        @map("lot_amount")
  marginMultiple     Float?        @map("margin_multiple")
  subscribeStart     DateTime?     @map("subscribe_start")
  subscribeEnd       DateTime?     @map("subscribe_end")
  listingDate        DateTime?     @map("listing_date")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at")
  events             IpoEvent[]
  accountIpos        AccountIpo[]
  analysis           IpoAnalysis?

  @@map("ipo")
}

model IpoEvent {
  id        String   @id @default(cuid())
  ipoId     String   @map("ipo_id")
  type      String
  title     String
  eventDate DateTime @map("event_date")
  pdfUrl    String?  @map("pdf_url")
  createdAt DateTime @default(now()) @map("created_at")
  ipo       Ipo      @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@index([ipoId])
  @@index([eventDate])
  @@map("ipo_event")
}

model Account {
  id                 String         @id @default(cuid())
  name               String
  broker             String?
  brokerProfileId    String?        @map("broker_profile_id")
  accountSuffix      String?        @map("account_suffix")
  phone              String?        @default("")
  securitiesAccount  String?        @map("securities_account")
  initialDeposit     Float          @default(0) @map("initial_deposit")
  currentAssets      Float          @default(0) @map("current_assets")
  defaultSubscriptionMethod String?  @map("default_subscription_method")
  currency           String         @default("HKD")
  cash               Float          @default(0)
  frozen             Float          @default(0)
  marginLimit        Float          @default(0) @map("margin_limit")
  availableMargin    Float          @default(0) @map("available_margin")
  financingMultiple  Float          @default(10) @map("financing_multiple")
  status             String         @default("active")
  note               String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @default(now()) @updatedAt @map("updated_at")
  brokerProfile      BrokerProfile? @relation(fields: [brokerProfileId], references: [id], onDelete: SetNull)
  accountIpos        AccountIpo[]
  withdrawals        Withdrawal[]
  exchangeRecords    ExchangeRecord[]

  @@index([brokerProfileId])
  @@index([status])
  @@map("account")
}

model BrokerProfile {
  id                   String    @id @default(cuid())
  name                 String    @unique
  defaultMarginMultiple Float    @default(10) @map("default_margin_multiple")
  defaultFee           Float     @default(100) @map("default_fee")
  defaultFinancingRate Float     @default(0) @map("default_financing_rate")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")
  accounts             Account[]

  @@map("broker_profile")
}

model AccountIpo {
  id                 String   @id @default(cuid())
  accountId          String   @map("account_id")
  ipoId              String   @map("ipo_id")
  applyLots          Int      @default(0) @map("apply_lots")
  applyAmount        Float    @default(0) @map("apply_amount")
  status             String   @default("watching")
  subscriptionMethod String?  @map("subscription_method")
  subscriptionDate   DateTime? @map("subscription_date")
  remarks            String?
  allottedShares     Int      @default(0) @map("allotted_shares")
  allottedLots       Int      @default(0) @map("allotted_lots")
  sellPlan           String?  @map("sell_plan")
  commission         Float    @default(0)
  financingFee       Float    @default(0) @map("financing_fee")
  profit             Float    @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")
  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ipo                Ipo      @relation(fields: [ipoId], references: [id], onDelete: Cascade)
  sellRecords        SellRecord[]

  @@index([accountId])
  @@index([ipoId])
  @@index([status])
  @@map("account_ipo")
}

model SellRecord {
  id           String     @id @default(cuid())
  accountIpoId String     @map("account_ipo_id")
  price        Float      @default(0)
  date         DateTime?
  shares       Int        @default(0)
  method       String?
  commission   Float      @default(0)
  remarks      String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at")
  accountIpo   AccountIpo @relation(fields: [accountIpoId], references: [id], onDelete: Cascade)

  @@index([accountIpoId])
  @@index([date])
  @@map("sell_record")
}

model ExchangeRecord {
  id              String   @id @default(cuid())
  accountId       String   @map("account_id")
  date            DateTime?
  sourceCurrency  String   @default("CNY") @map("source_currency")
  sourceAmount    Float    @default(0) @map("source_amount")
  sourceAmountCny Float    @default(0) @map("source_amount_cny")
  targetCurrency  String   @default("HKD") @map("target_currency")
  targetAmount    Float    @default(0) @map("target_amount")
  exchangeRate    Float    @default(0) @map("exchange_rate")
  manualRate      Float?   @map("manual_rate")
  originalCostCny Float    @default(0) @map("original_cost_cny")
  feeCny          Float    @default(0) @map("fee_cny")
  channel         String?
  remarks         String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([date])
  @@map("exchange_record")
}

model Withdrawal {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  date      DateTime?
  amount    Float    @default(0)
  remarks   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([date])
  @@map("withdrawal")
}

model IpoAnalysis {
  ipoId        String   @id @map("ipo_id")
  rating       String?
  recommendation String?
  risk         String?
  expectedDark Float?   @map("expected_dark")
  note         String?
  ipo          Ipo      @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@map("ipo_analysis")
}
